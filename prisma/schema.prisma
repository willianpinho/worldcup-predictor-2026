// World Cup Predictor 2026 — Claude vs Gemini PoC
// Prisma 7 with the new `prisma-client` generator + libSQL driver adapter (SQLite file).
// SQLite has no native enums, so `status` and `model` are plain strings guarded in app code.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// One fixture: the 72 group-stage matches (stage GROUP) plus the 32 knockout
/// fixtures (stages R32..F). Knockout rows start with placeholder team codes
/// (e.g. "2A", "W73") that fill in with real names as the tournament progresses.
model Match {
  id        Int      @id @default(autoincrement())
  extId     String?  @unique // API-Football fixture id / "wc-ko-<num>" (idempotent seed/sync)
  stage     String   @default("GROUP") // GROUP | R32 | R16 | QF | SF | TP | F (guarded in app code)
  matchNum  Int?     @unique // official FIFA match number 73..104 (null for group)
  groupName String // 'A'..'L' for group rows; the stage code for knockout rows
  teamA     String
  teamB     String
  venue     String?
  city      String?
  country   String?
  kickoff   DateTime
  status    String   @default("SCHEDULED") // SCHEDULED | LIVE | FINISHED
  scoreA    Int?
  scoreB    Int?
  pensA     Int? // penalty-shootout score (knockout only)
  pensB     Int?
  round     Int      @default(1) // matchday within the group (1..3); 1 for knockout

  predictions Prediction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupName])
  @@index([kickoff])
  @@index([stage])
}

/// One AI's prediction for a match. Unique per (match, model, condition).
model Prediction {
  id      Int   @id @default(autoincrement())
  matchId Int
  match   Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  model      String // 'claude' | 'gemini'
  condition  String  @default("web") // experiment arm: 'web' | 'baseline' | 'enriched'
  predA      Int
  predB      Int
  probWinA   Float? // 0..100
  probDraw   Float? // 0..100
  probWinB   Float? // 0..100
  confidence String? // 'high' | 'medium' | 'low'
  reasoning  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, model, condition])
}
