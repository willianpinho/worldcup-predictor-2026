# Copy to .env and fill in. NEVER commit .env with real values.

# SQLite file (libSQL adapter). Relative to project root / prisma.config.ts.
DATABASE_URL="file:./prisma/data.db"

# Results auto-sync uses the FIFA API by default (free, no key, real-time origin).
# These vars only override the defaults; leave unset for the 2026 World Cup.
#   FIFA_COMPETITION_ID="17"     # FIFA World Cup
#   FIFA_SEASON_ID="285023"      # FIFA World Cup 2026
#   FIFA_SYNC_DISABLED="1"       # set to fall back to API-Football / openfootball

# API-Football (api-sports.io) — OPTIONAL secondary results feed. Empty = skipped.
# Seeding always uses openfootball (it carries groups + grounds).
FOOTBALL_API_KEY=""

# API-Football competition coords for the 2026 World Cup.
FOOTBALL_LEAGUE_ID="1"
FOOTBALL_SEASON="2026"

# Protects /admin actions and the import/sync endpoints. Generate a long random value.
ADMIN_TOKEN="change-me-admin-token"

# Shared secret the cron sidecar sends to POST /api/results/sync.
CRON_SECRET="change-me-cron-secret"
